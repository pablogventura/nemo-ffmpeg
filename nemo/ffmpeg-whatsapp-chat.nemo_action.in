[Nemo Action]
Version=1.0
Type=Application
Encoding=UTF-8
Name=FFmpeg: Vídeo WhatsApp (chat)
Comment=Prepara vídeo MP4 de hasta 16 MB para enviar como multimedia en WhatsApp
Exec=@INSTALL_LIB@ %F
Icon-Name=video-x-generic
Selection=any
Mimetypes=video/mp4;video/x-matroska;video/quicktime;video/webm;video/x-msvideo;video/x-ms-wmv;video/3gpp;video/ogg;video/x-flv;video/x-ms-asf;
Dependencies=ffmpeg;
Terminal=true
Quote=double
