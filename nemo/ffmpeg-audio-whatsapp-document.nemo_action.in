[Nemo Action]
Version=1.0
Type=Application
Encoding=UTF-8
Name=FFmpeg: Audio WhatsApp (documento)
Comment=Convierte audio a MP3 de alta calidad para enviar como documento en WhatsApp (hasta 2 GB)
Exec=@INSTALL_LIB@ %F
Icon-Name=audio-x-generic
Selection=any
Mimetypes=audio/flac;audio/wav;audio/x-wav;audio/ogg;audio/x-vorbis+ogg;audio/mpeg;audio/mp4;audio/x-m4a;audio/aac;audio/x-ms-wma;audio/webm;audio/opus;
Dependencies=ffmpeg;
Terminal=true
Quote=double
