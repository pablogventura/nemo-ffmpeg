[Nemo Action]
Version=1.0
Type=Application
Encoding=UTF-8
Name=FFmpeg: Convertir a MP3
Comment=Convierte audio o extrae audio de vídeo a MP3
Exec=@INSTALL_LIB@ %F
Icon-Name=audio-x-generic
Selection=any
Mimetypes=audio/flac;audio/wav;audio/x-wav;audio/ogg;audio/x-vorbis+ogg;audio/mpeg;audio/mp4;audio/x-m4a;audio/aac;audio/x-ms-wma;audio/webm;audio/opus;video/mp4;video/x-matroska;video/quicktime;video/webm;video/x-msvideo;video/x-ms-wmv;video/3gpp;
Dependencies=ffmpeg;
Terminal=true
Quote=double
